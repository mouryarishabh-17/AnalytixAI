# Database Configuration
MONGO_URL=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/
DB_NAME=analytixai

# JWT Authentication
SECRET_KEY=your-secret-key-here-generate-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# Server Settings
HOST=127.0.0.1
PORT=8000

# Google Gemini API (Get from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Email Configuration (Gmail SMTP - Generate App Password from Google Account)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
FROM_EMAIL=your-email@gmail.com
FROM_NAME=AnalytixAI

# Frontend URL (for email links)
FRONTEND_URL=http://127.0.0.1:5500

# Admin Configuration
ADMIN_EMAIL=admin@analytixai.com
ADMIN_PASSWORD=change_this_secure_admin_password
